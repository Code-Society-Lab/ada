{
  "$schema": "https://schema.railpack.com",
  "buildAptPackages": ["git"],
  "steps": {
    "install": {
      "inputs": [{ "local": true, "include": ["."] }],
      "commands": ["pip install ."]
    }
  },
  "deploy": {
    "aptPackages": ["git"],
    "startCommand": "python bot start --env production"
  }
}
