{
  "$schema": "https://schema.railpack.com",
  "buildAptPackages": ["git", "libpq-dev", "python3-dev", "postgresql"],
  "steps": {
    "install": {
      "commands": [
        { "src": ".", "dest": "." },
        "pip install psycopg2-binary && pip install ."
      ]
    }
  },
  "deploy": {
    "aptPackages": ["git", "libpq-dev", "python3-dev", "postgresql"],
    "startCommand": "python bot --env production start"
  }
}
