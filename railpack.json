{
  "$schema": "https://schema.railpack.com",

  "buildAptPackages": [
    "git",
    "libpq-dev",
    "python3-dev",
    "postgresql"
  ],

  "steps": {
    "install": {
      "commands": [
        { "src": ".", "dest": "." },

        "python3 -m venv .venv",
        ".venv/bin/pip install --upgrade pip",

        ".venv/bin/pip install psycopg2-binary",
        ".venv/bin/pip install ."
      ]
    }
  },

  "deploy": {
    "aptPackages": [
      "git",
      "libpq-dev",
      "python3-dev",
      "postgresql"
    ],

    "startCommand": ".venv/bin/python bot --env production start"
  }
}
