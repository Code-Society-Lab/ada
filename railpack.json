{
  "$schema": "https://schema.railpack.com",
  "buildAptPackages": ["git"],
  "steps": {
    "install": {
      "commands": [
        { "src": ".", "dest": "." },
        "pip install ."
      ]
    }
  },
  "deploy": {
    "aptPackages": ["git"],
    "startCommand": "python bot start --env production"
  }
}
